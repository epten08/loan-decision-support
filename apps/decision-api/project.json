{
  "name": "decision-api",
  "root": "apps/decision-api",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "gradlew.bat build",
        "cwd": "apps/decision-api"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "gradlew.bat bootRun",
        "cwd": "apps/decision-api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "gradlew.bat test",
        "cwd": "apps/decision-api"
      }
    }
  }
}